{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@diagram-generator/layout-engine": [
        "../../packages/layout-engine/src/index.ts"
      ],
      "@diagram-generator/graph-layout-core": [
        "../../packages/graph-layout-core/src/index.ts"
      ],
      "@diagram-generator/graph-layout-elk": [
        "../../packages/graph-layout-elk/src/index.ts"
      ]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ]
}
